{
  "lastChangelogVersion": "0.64.0",
  "defaultProvider": "google-antigravity",
  "defaultModel": "gemini-3.1-pro-low",
  "enabledModels": [
    "claude-*",
    "gpt-5.4*",
    "gpt-5.3*",
    "kimi-k2",
    "openai-gpt*",
    "gemini-3.1*"
  ],
  "theme": "dark",
  "steeringMode": "one-at-a-time",
  "packages": [
    "git:github.com/badlogic/pi-mono/"
  ],
  "transport": "sse",
  "skills": [
    "~/.agents/skills/"
  ],
  "showHardwareCursor": false,
  "hideThinkingBlock": false,
  "compaction": {
    "enabled": true
  },
  "defaultThinkingLevel": "high",
  "terminal": {
    "showImages": false
  },
  "images": {
    "autoResize": false
  },
  "collapseChangelog": true,
  "quietStartup": true,
  "doubleEscapeAction": "tree",
  "treeFilterMode": "default"
}