{
  "$schema": "https://charm.land/crush.json",
  "tools": {
    "ls": {},
    "grep": {}
  },
  "options": {
    "attribution": {
      "trailer_style": "none",
      "generated_with": false
    },
    "context_paths": ["~/.agents/AGENTS.md"],
    "skills_paths": ["~/.agents/skills/"]
  },
  "mcp": {
    "xcode": {
      "type": "stdio",
      "command": "xcrun",
      "args": ["mcpbridge"],
      "disabled": true
    }
   },
  "lsp": {
    "typeprof": {
      "disabled": true
    },
    "solargraph": {
      "disabled": true
    },
    "rubocop": {
      "disabled": true
    },
    "sourcekit": {
      "command": "sourcekit-lsp",
      "root_markers": ["Package.swift", "."],
      "filetypes": ["swift", "objective-c", "cpp"],
      "disabled": true
    }
  },
  "providers": {
    "cli-proxy-api-plus": {
